rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isPublicFamily(familyId) {
      return familyId == 'ayivon';
    }

    function isLegacyAyivonFamily(familyId) {
      return familyId == 'family-ayivon';
    }

    function hasRoleDocument() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/user_roles/$(request.auth.uid));
    }

    function currentRole() {
      return get(
        /databases/$(database)/documents/user_roles/$(request.auth.uid)
      ).data;
    }

    function isActiveUser() {
      return hasRoleDocument() && currentRole().active == true;
    }

    function hasFamilyAccess(familyId) {
      return isActiveUser() && familyId in currentRole().familyIds;
    }

    function hasAnyRole(roles) {
      return isActiveUser() && currentRole().role in roles;
    }

    function isEditor(familyId) {
      return hasFamilyAccess(familyId) &&
        hasAnyRole(['editor', 'admin', 'superAdmin']);
    }

    function isAdmin(familyId) {
      return hasFamilyAccess(familyId) &&
        hasAnyRole(['admin', 'superAdmin']);
    }

    function isSuperAdmin() {
      return hasAnyRole(['superAdmin']);
    }

    function isSuperAdminAyivonMigration(previousFamilyId, nextFamilyId) {
      return isSuperAdmin() &&
        isLegacyAyivonFamily(previousFamilyId) &&
        nextFamilyId == 'ayivon';
    }

    function hasValidNextVersion() {
      return (
        !('version' in resource.data) &&
        request.resource.data.version == 1
      ) || request.resource.data.version == resource.data.version + 1;
    }

    match /families/{familyId} {
      allow read: if isPublicFamily(familyId) || hasFamilyAccess(familyId);
      allow create, update: if isEditor(familyId);
      allow delete: if isSuperAdmin();
    }

    match /members/{memberId} {
      allow read: if isPublicFamily(resource.data.familyId) ||
        hasFamilyAccess(resource.data.familyId) ||
        (isLegacyAyivonFamily(resource.data.familyId) &&
          hasFamilyAccess('ayivon'));
      allow create: if isEditor(request.resource.data.familyId);
      allow update: if (
        isEditor(resource.data.familyId) &&
        request.resource.data.familyId == resource.data.familyId &&
        hasValidNextVersion()
      ) || (
        isSuperAdminAyivonMigration(
          resource.data.familyId,
          request.resource.data.familyId
        ) &&
        hasValidNextVersion()
      );
      allow delete: if isAdmin(resource.data.familyId);
    }

    match /relationships/{relationshipId} {
      allow read: if isPublicFamily(resource.data.familyId) ||
        hasFamilyAccess(resource.data.familyId);
      allow create: if isEditor(request.resource.data.familyId);
      allow update: if isEditor(resource.data.familyId) &&
        request.resource.data.familyId == resource.data.familyId;
      allow delete: if isAdmin(resource.data.familyId);
    }

    match /family_tree_links/{linkId} {
      allow read: if isPublicFamily(resource.data.familyId) ||
        hasFamilyAccess(resource.data.familyId);
      allow create: if isEditor(request.resource.data.familyId);
      allow update: if isEditor(resource.data.familyId) &&
        request.resource.data.familyId == resource.data.familyId;
      allow delete: if isAdmin(resource.data.familyId);
    }

    match /notifications/{notificationId} {
      allow read: if isPublicFamily(resource.data.familyId) ||
        hasFamilyAccess(resource.data.familyId);
      allow create: if isEditor(request.resource.data.familyId);
      allow update: if isEditor(resource.data.familyId) &&
        request.resource.data.familyId == resource.data.familyId;
      allow delete: if isAdmin(resource.data.familyId);
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin(resource.data.familyId);
      allow create: if isEditor(request.resource.data.familyId);
      allow update, delete: if false;
    }

    match /sync_incidents/{incidentId} {
      allow read: if isAdmin(resource.data.familyId);
      allow create: if isAuthenticated() &&
        request.resource.data.familyId == 'ayivon' &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin(resource.data.familyId);
      allow delete: if isSuperAdmin();
    }

    match /settings/{settingId} {
      allow read: if settingId == 'admin_notifications' && isAdmin('ayivon');
      allow write: if settingId == 'admin_notifications' && isSuperAdmin();
    }

    match /user_roles/{userId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isSuperAdmin());
      allow create, update, delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
